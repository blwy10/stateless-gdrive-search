# Project rule: env vars are explicit — no silent defaults (see "Environment
# variables" in AGENTS.md). Everything below without a leading "#" is REQUIRED.
# The commented-out lines are the only genuinely-optional vars (a true no-op when
# unset): the *_BASE_URL endpoints, DATABASE_SSL, and the DEBUG_* / AGENT_* knobs.

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/stateless_gdrive_search
# Postgres SSL mode (optional). Leave unset for local dev and for Railway's
# private-network Postgres (no TLS). Use `require` for hosted Postgres that
# presents a self-signed cert, or `verify` to check the cert against system CAs.
# DATABASE_SSL=require
TOKEN_ENCRYPTION_KEY=
AI_API_KEY=
# Required. Model provider family: "openai" (Responses API), "anthropic", or
# "openai-compatible" (Fireworks/vLLM/custom).
AI_PROVIDER=openai
# Optional. Native providers (openai, anthropic) use their official endpoint when
# unset; "openai-compatible" requires it (e.g. https://api.fireworks.ai/inference/v1).
# AI_BASE_URL=
# Required. Model id for the main role.
AI_MODEL=gpt-4.1-mini
# Required reasoning effort: "none" | "minimal" | "low" | "medium" | "high".
# "none" is the explicit "provider default" (the option is omitted). OpenAI /
# openai-compatible receive it as reasoning_effort; Anthropic has no such param,
# so it maps to an extended-thinking budget ("none" = thinking off). Ignored by
# non-reasoning models. An unrecognized value fails at startup.
AI_REASONING_EFFORT=none

# Grader model (REQUIRED). The grader is a separate, cheaper model used only to
# judge per-file relevance — much lower requirements than the main agent — and
# there is NO fallback to the main model, so both must be configured.
GRADER_AI_API_KEY=
# Required. Provider family for the grader: "openai", "anthropic", or "openai-compatible".
GRADER_AI_PROVIDER=openai
# Optional; required for "openai-compatible" (e.g. https://api.fireworks.ai/inference/v1).
# GRADER_AI_BASE_URL=
GRADER_AI_MODEL=
# Required reasoning effort for the grader (see AI_REASONING_EFFORT). Lowering this
# (e.g. "low"/"minimal") is often the cheapest cost lever for the grader's
# high-volume classify+extract; use "none" for the provider default.
GRADER_AI_REASONING_EFFORT=none

# Summarizer model (REQUIRED). A separate model used only to condense an oversize
# file — one whose extracted text would otherwise be hard-truncated — into the
# synthesis budget, so the whole file's substance reaches the answer instead of
# just its first ~8k tokens. Only runs on the synthesis path (open_file), and only
# for the minority of files that exceed the cap. There is NO fallback to another
# role, so all four behaviour vars below must be set (a summarizer failure falls
# back to plain truncation at run time, but the config itself is required). Prefer
# a large-context model here — that is the whole point of this role.
SUMMARIZER_AI_API_KEY=
# Required. Provider family for the summarizer: "openai", "anthropic", or "openai-compatible".
SUMMARIZER_AI_PROVIDER=openai
# Optional; required for "openai-compatible" (e.g. https://api.fireworks.ai/inference/v1).
# SUMMARIZER_AI_BASE_URL=
SUMMARIZER_AI_MODEL=
# Required reasoning effort for the summarizer (see AI_REASONING_EFFORT). Faithful
# compression rarely needs chain-of-thought, so "none"/"low" is usually enough.
SUMMARIZER_AI_REASONING_EFFORT=none
# Master switch for local JSONL agent traces. Local only: forced off (and
# stripped from the build) when NODE_ENV=production, which disables every
# DEBUG_* flag below too.
DEBUG_LOGS=0
DEBUG_LOG_CONTENT=0
# Full model-transcript dump (assistant reasoning + answer + tool-call args +
# raw response body per step) for tracing curation decisions. Reasoning is read
# from the AI SDK's unified reasoningText, so it appears the same across OpenAI,
# Anthropic, and OpenAI-compatible providers. Curated-mode relevance-grader calls
# log distinctly under agent.grade.* (vs the main agent's agent.model.*).
# Verbose/sensitive; local only, forced off when NODE_ENV=production. Requires DEBUG_LOGS=1.
DEBUG_LOG_TRANSCRIPT=0

# Per-user abuse protection on /api/agent (optional; defaults shown).
# AGENT_MAX_CONCURRENT_RUNS: max simultaneous runs per user.
# AGENT_RATE_LIMIT_BURST: token-bucket capacity (immediate burst per user).
# AGENT_RATE_LIMIT_PER_MINUTE: sustained runs allowed per user per minute.
AGENT_MAX_CONCURRENT_RUNS=2
AGENT_RATE_LIMIT_BURST=10
AGENT_RATE_LIMIT_PER_MINUTE=20

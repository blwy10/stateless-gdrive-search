NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/stateless_gdrive_search
# Postgres SSL mode (optional). Leave unset for local dev and for Railway's
# private-network Postgres (no TLS). Use `require` for hosted Postgres that
# presents a self-signed cert, or `verify` to check the cert against system CAs.
# DATABASE_SSL=require
TOKEN_ENCRYPTION_KEY=
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
DEBUG_LOGS=0
DEBUG_LOG_CONTENT=0

# Per-user abuse protection on /api/agent (optional; defaults shown).
# AGENT_MAX_CONCURRENT_RUNS: max simultaneous runs per user.
# AGENT_RATE_LIMIT_BURST: token-bucket capacity (immediate burst per user).
# AGENT_RATE_LIMIT_PER_MINUTE: sustained runs allowed per user per minute.
AGENT_MAX_CONCURRENT_RUNS=2
AGENT_RATE_LIMIT_BURST=10
AGENT_RATE_LIMIT_PER_MINUTE=20
